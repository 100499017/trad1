(setq x 15)
(setq y 5)
(setq res 0)
(defun main ()
(print "Probando operaciones aritméticas:")
(setf res (+ x y))
(progn (princ res)
(princ " "))
(setf res (- x y))
(progn (princ res)
(princ " "))
(setf res (* x y))
(progn (princ res)
(princ " "))
(setf res (/ x y))
(progn (princ res)
(princ " "))
(setf res (mod x y))
(princ res)

)
 (main)
