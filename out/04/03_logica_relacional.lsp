(setq a 1)
(setq b 0)


(defun main ()
(print "Probando logica y relacionales:")
(if (> a b)
(print "1 es mayor a 0")
)
(if (< b a)
(print "0 es menor que 1")
)
(if (>= a b)
(print "1 es mayor o igual a 0")
)
(if (<= b a)
(print "0 es menor o igual a 1")
)
(if (= a b)
(print "1 es igual a 0")
)
(if (/= a b)
(print "1 es distinto de 0")
)
(if (and a (not b))
(print "A es verdadero y B es falso")
)
(if (or a b)
(print "A o B es verdadero")
)

)
 (main)
